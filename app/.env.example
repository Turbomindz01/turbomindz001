# ════════════════════════════════════════════════════════
# Turbomindz Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.
# ════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── thirdweb (wallet connect, 170+ wallets) ────────────
# Get a Client ID at https://thirdweb.com/dashboard
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-client-id-here

# ─── Supabase (MP4, Day 14+) ────────────────────────────
# Project URL + keys at https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by Next.js API routes for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenSea (Day 14-15, sync 150 minted NFTs) ──────────
# OPENSEA_API_KEY=

# ─── Pinata IPFS (Week 8) ───────────────────────────────
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=

# ─── Buttondown newsletter (Week 11+) ───────────────────
# BUTTONDOWN_API_KEY=
